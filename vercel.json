{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://lifetracker.vercel.app"
  },
  "crons": [
    { "path": "/api/telegram/cron", "schedule": "0 * * * *" },
    { "path": "/api/telegram/cron", "schedule": "30 * * * *" }
  ]
}
