rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated and owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection — users can only read/write their own doc
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Health subcollections (written client-side with auth — no userId field needed)
      match /health_logs/{docId} {
        allow read, write: if isOwner(userId);
      }
      match /workout_logs/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // All other collections use userId field for ownership
    // These rules apply to: habits, daily_summaries, daily_habit_logs,
    // sleep_logs, weight_logs, screen_time_logs, food_logs, goals, milestones,
    // daily_actions, books, todos, time_entries, custom_counters, counter_logs,
    // user_xp, xp_events, badges, daily_insights, correlations, weekly_reflections,
    // daily_energy_logs, pomodoro_sessions, task_breakdowns, checkin_logs,
    // overwhelm_sessions, inbox, surprise_insights, vitals_logs

    match /{collection}/{docId} {
      allow read, write: if request.auth != null
        && (
          // Updating an existing document — must own it
          (resource != null && resource.data.userId == request.auth.uid)
          // Creating a new document — new data must have caller's userId
          || (resource == null && request.resource.data.userId == request.auth.uid)
        );
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
