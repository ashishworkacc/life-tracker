# ============================================================
# LifeTracker — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ------ Firebase (firebase.google.com → Project Settings → Your apps) ------
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin SDK (server-side — used by Telegram bots and API routes)
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Minify the JSON to a single line: jq -c . firebase-admin-key.json
# Then paste the entire minified string as the value below
FIREBASE_SERVICE_ACCOUNT=

# Firebase Vapid Key (for push notifications via FCM)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# ------ OpenRouter AI (openrouter.ai → Keys) ------
# DeepSeek V3 is the default model — cheap and capable for all AI features
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat

# ------ Telegram — Check-in Bot -----------------------------------------------
# Create a bot via @BotFather → /newbot → copy the token it gives you
TELEGRAM_BOT_TOKEN=
# Public username of your check-in bot (shown to users in Settings → setup instructions)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# Webhook secret: random 32-char string to authenticate Telegram's POST requests
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=

# ------ Telegram — Food Logger Bot --------------------------------------------
# Create a second bot via @BotFather for food logging
TELEGRAM_FOOD_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_FOOD_BOT_USERNAME=your_food_bot_username

# ------ Cron Security ---------------------------------------------------------
# Random secret used to authenticate calls to /api/telegram/cron from your scheduler
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# ------ App URL ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to your production URL before deploying: https://your-app.vercel.app
