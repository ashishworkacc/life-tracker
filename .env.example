# ============================================================
# LifeTracker — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ------ Firebase (firebase.google.com → Project Settings → Your apps) ------
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (for Cloud Functions — path to downloaded JSON from Service Accounts)
# Download from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Save file as firebase-admin-key.json in project root (it is gitignored)
FIREBASE_ADMIN_KEY_PATH=./firebase-admin-key.json

# Firebase Vapid Key (for push notifications via FCM)
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# ------ OpenRouter AI (openrouter.ai → Keys) ------
# DeepSeek V3 is the default model — extremely cheap (~₹0.01 per AI call)
# You can change the model anytime by updating OPENROUTER_DEFAULT_MODEL
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat

# Other available models you can use:
# google/gemini-flash-1.5     → Free tier available, fast
# gpt-4o-mini                 → Reliable, good instruction following
# qwen/qwen-2.5-72b-instruct  → Strong multilingual (Hindi/English)

# ------ App URL ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to your Vercel URL before deploying: https://lifetracker.vercel.app

# ------ Razorpay (add later when implementing payments) ------
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_PLAN_MONTHLY=plan_...
